  <div class="panel-section">
    <div class="panel-section-title">Appointment</div>
    <div class="panel-row"><span class="panel-key">Date</span><span class="panel-val" id="panel-date">—</span></div>
    <div class="panel-row"><span class="panel-key">Time</span><span class="panel-val" id="panel-time">—</span></div>
    <div class="panel-row"><span class="panel-key">Services</span><span class="panel-val" id="panel-services">—</span></div>
    <div class="panel-row"><span class="panel-key">Address</span><span class="panel-val" id="panel-address" style="max-width:180px;text-align:right;font-size:12px;">—</span></div>
  </div>

  <div class="panel-section">
    <div class="panel-section-title">Client</div>
    <div class="panel-row"><span class="panel-key">Name</span><span class="panel-val" id="panel-client-name">—</span></div>
    <div class="panel-row"><span class="panel-key">Phone</span><span class="panel-val" id="panel-phone">—</span></div>
    <div class="panel-row"><span class="panel-key">Email</span><span class="panel-val" id="panel-email" style="font-size:11px;">—</span></div>
  </div>

  <div class="panel-section">
    <div class="panel-section-title">Payment</div>
    <div class="panel-row"><span class="panel-key">Total</span><span class="panel-val" id="panel-total">—</span></div>
    <div class="panel-row"><span class="panel-key">Deposit</span><span class="panel-val" id="panel-deposit">—</span></div>
    <div class="panel-row"><span class="panel-key">Balance Due</span><span class="panel-val" id="panel-balance">—</span></div>
    <div class="panel-row"><span class="panel-key">Balance Status</span><span class="panel-val" id="panel-bal-status">—</span></div>
  </div>

  <div class="action-grid">
    <button class="action-btn" onclick="panelAction('Confirmed')">✓ Confirm</button>
    <button class="action-btn" onclick="panelAction('reschedule')">↻ Reschedule</button>
    <button class="action-btn" onclick="panelAction('Service Complete')">✦ Service Complete</button>
    <button class="action-btn danger" onclick="panelAction('Cancelled')">✕ Cancel</button>
    <button class="action-btn primary" onclick="panelAction('requestBalance')">💳 Request Balance Payment</button>
  </div>
</div><!-- /detail-panel -->

</div><!-- /pg-app -->

<div class="toast" id="toast"></div>

<script>
// ══════════════════════════════════════════════════════
// PHENOMEBEAUTY ADMIN — FIXED v2
// ══════════════════════════════════════════════════════
const API = '';
let token = sessionStorage.getItem('pbAdminToken') || '';
let allBookings = [], allConsults = [], allLoyalty = [], allStock = [];
let currentFilter = 'All', currentLoyaltyFilter = 'All', currentBookingId = '';
let loyaltyLoaded = false, stockLoaded = false;

// ── LOGIN / LOGOUT ──────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  if (token) { showApp(); } else { showLoginPage(); }
});

function showLoginPage() {
  document.getElementById('pg-login').classList.remove('hidden');
  document.getElementById('pg-app').style.display = 'none';
}

function showApp() {
  document.getElementById('pg-login').classList.add('hidden');
  document.getElementById('pg-app').style.display = 'flex';
  init();
}

async function doLogin() {
  const btn = document.getElementById('l-btn');
  const pass = document.getElementById('l-pass').value;
  const err = document.getElementById('l-err');
  if (!pass) return;
  btn.disabled = true;
  btn.innerHTML = '<span class="login-spinner"></span>';
  err.style.display = 'none';
  try {
    const r = await fetch('/api/admin/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ password: pass })
    });
    const ct = r.headers.get('content-type') || '';
    if (!ct.includes('application/json')) throw new Error('Server error — is the app deployed?');
    const d = await r.json();
    if (!r.ok || !d.token) throw new Error(d.error || 'Incorrect password');
    token = d.token;
    sessionStorage.setItem('pbAdminToken', token);
    showApp();
  } catch(e) {
    err.textContent = e.message;
    err.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'Sign In';
  }
}

function doLogout() {
  sessionStorage.removeItem('pbAdminToken');
  token = '';
  allBookings = []; allConsults = []; allLoyalty = []; allStock = [];
  loyaltyLoaded = false; stockLoaded = false;
  closeSidebar();
  document.getElementById('l-pass').value = '';
  document.getElementById('l-btn').textContent = 'Sign In';
  document.getElementById('l-btn').disabled = false;
  document.getElementById('l-err').style.display = 'none';
  showLoginPage();
  showToast('Signed out');
}

// ── MOBILE SIDEBAR ──────────────────────────────────
function openSidebar() {
  document.querySelector('.sidebar').classList.add('mobile-open');
  document.getElementById('sb-overlay').classList.add('show');
}
function closeSidebar() {
  document.querySelector('.sidebar').classList.remove('mobile-open');
  document.getElementById('sb-overlay').classList.remove('show');
}

// ── API CALL ────────────────────────────────────────
function apiCall(url, opts = {}) {
  opts.headers = { ...(opts.headers || {}), 'x-admin-token': token, 'Content-Type': 'application/json' };
  return fetch(API + url, opts).then(r => {
    if (r.status === 401) { doLogout(); throw new Error('Session expired'); }
    return r;
  });
}

// ── NAV ─────────────────────────────────────────────
const viewTitles = {
  dashboard:'Dashboard', bookings:'Bookings', consults:'New Divas',
  loyalty:'Loyalty Tracker', availability:'Availability', stock:'Stock',
  integrations:'Integrations', settings:'Settings'
};

function show(view, el) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('view-' + view).classList.add('active');
  if (el) el.classList.add('active');
  document.getElementById('topbar-title').textContent = viewTitles[view] || view;
  closePanel();
  closeSidebar();
  if (view === 'dashboard')    loadDashboard();
  if (view === 'bookings')     renderBookings();
  if (view === 'consults')     renderConsults();
  if (view === 'loyalty')      { if (!loyaltyLoaded) loadLoyalty(); else renderLoyalty(); }
  if (view === 'availability') renderAvailability();
  if (view === 'stock')        { if (!stockLoaded) loadStock(); else renderStock(); }
  if (view === 'settings')     loadSettings();
}

// ── FILTER CHIPS ────────────────────────────────────
function fc(chip) {
  chip.closest('.filter-row').querySelectorAll('.chip').forEach(c => c.classList.remove('on'));
  chip.classList.add('on');
}

// ── BOOKINGS ─────────────────────────────────────────
async function loadBookings() {
  try {
    const r = await apiCall('/api/admin/bookings');
    const d = await r.json();
    // API returns array directly; field names: name, services, date, time, status, total, deposit, balanceDue, phone, email, address, bookingId, balanceStatus, checkoutId, calEventId
    allBookings = Array.isArray(d) ? d : (d.bookings || []);
    updateBadges();
    renderBookings();
  } catch(e) { showToast('Bookings error: ' + e.message); }
}

function filterBookings(f) { currentFilter = f; renderBookings(); }

function renderBookings() {
  const list = document.getElementById('booking-list');
  const today = new Date().toISOString().slice(0,10);
  let items = allBookings;
  if (currentFilter !== 'All') {
    if (currentFilter === 'Today') items = items.filter(b => b.date === today);
    else items = items.filter(b => b.status === currentFilter);
  }
  if (!items.length) { list.innerHTML = '<div class="data-note">No bookings found.</div>'; return; }

  list.innerHTML = items.map(b => {
    const name = b.name || '—';
    const svc  = b.services || '—';
    const stat = b.status || 'Pending Payment';
    const total = b.total || '0';
    const id   = b.bookingId || '';
    const sc   = stat === 'Pending Payment' ? 's-pending' : stat === 'Confirmed' ? 's-confirmed' : stat === 'Service Complete' ? 's-complete' : stat === 'Cancelled' ? 's-cancelled' : 's-pending';
    return `<div class="card booking-row" onclick="openPanel('${esc(id)}')">
      <div class="booking-avatar">${(name[0]||'?').toUpperCase()}</div>
      <div>
        <div class="booking-name">${esc(name)}</div>
        <div class="booking-meta">${esc(svc.split(',')[0])} · ${fmtD(b.date)} · ${b.time||''}</div>
      </div>
      <div class="booking-amount">R ${Number(total).toLocaleString()}</div>
      <div class="status-pill ${sc}">${stat === 'Pending Payment' ? 'Pending' : stat}</div>
    </div>`;
  }).join('');
}

function searchBookings(q) {
  if (!q) { renderBookings(); return; }
  const ql = q.toLowerCase();
  const items = allBookings.filter(b =>
    (b.name||'').toLowerCase().includes(ql) ||
    (b.services||'').toLowerCase().includes(ql) ||
    (b.bookingId||'').toLowerCase().includes(ql) ||
    (b.phone||'').toLowerCase().includes(ql)
  );
  const list = document.getElementById('booking-list');
  if (!items.length) { list.innerHTML = '<div class="data-note">No results for "' + esc(q) + '"</div>'; return; }
  const saved = allBookings; allBookings = items; renderBookings(); allBookings = saved;
}

// ── DETAIL PANEL ────────────────────────────────────
function openPanel(id) {
  const b = allBookings.find(x => x.bookingId === id);
  if (!b) return;
  currentBookingId = id;

  const stat = b.status || '—';
  const sc   = stat === 'Pending Payment' ? 's-pending' : stat === 'Confirmed' ? 's-confirmed' : stat === 'Service Complete' ? 's-complete' : stat === 'Cancelled' ? 's-cancelled' : 's-pending';

  document.getElementById('panel-name').textContent   = b.name || '—';
  document.getElementById('panel-ref').textContent    = id;
  document.getElementById('panel-status').textContent = stat;
  document.getElementById('panel-status').className   = 'status-pill ' + sc;
  document.getElementById('panel-date').textContent   = fmtD(b.date);
  document.getElementById('panel-time').textContent   = b.time || '—';
  document.getElementById('panel-services').textContent = b.services || '—';
  document.getElementById('panel-address').textContent  = b.address || '—';
  document.getElementById('panel-client-name').textContent = b.name || '—';
  document.getElementById('panel-phone').textContent  = b.phone || '—';
  document.getElementById('panel-email').textContent  = b.email || '—';
  document.getElementById('panel-total').textContent  = 'R ' + Number(b.total || 0).toLocaleString();
  document.getElementById('panel-deposit').textContent = 'R ' + Number(b.deposit || 0).toLocaleString();
  document.getElementById('panel-balance').textContent = 'R ' + Number(b.balanceDue || 0).toLocaleString();
  document.getElementById('panel-bal-status').textContent = b.balanceStatus || '—';

  document.getElementById('detail-panel').classList.add('open');
}

function closePanel() { document.getElementById('detail-panel').classList.remove('open'); }

async function panelAction(action) {
  if (!currentBookingId) return;
  if (action === 'requestBalance') {
    try {
      await apiCall('/api/admin/request-balance', { method:'POST', body: JSON.stringify({ bookingId: currentBookingId }) });
      showToast('Balance request sent ✓');
    } catch(e) { showToast('Error: ' + e.message); }
    closePanel(); return;
  }
  if (action === 'reschedule') { showToast('Reschedule — coming soon'); return; }
  // Update status
  try {
    await apiCall('/api/admin/update-status', { method:'POST', body: JSON.stringify({ bookingId: currentBookingId, status: action }) });
    showToast('Status → ' + action + ' ✓');
    await loadBookings();
  } catch(e) { showToast('Error: ' + e.message); }
  closePanel();
}

// ── CONSULTATIONS ────────────────────────────────────
async function loadConsults() {
  try {
    const r = await apiCall('/api/admin/consultations');
    const d = await r.json();
    allConsults = Array.isArray(d) ? d : [];
    updateBadges();
    renderConsults();
  } catch(e) { showToast('Consultations error: ' + e.message); }
}

function renderConsults() {
  const el = document.getElementById('consults-list');
  if (!allConsults.length) { el.innerHTML = '<div class="data-note">No consultations yet.</div>'; return; }
  el.innerHTML = allConsults.map(c => {
    const tags = [];
    if ((c.clientType||'').toLowerCase()==='new') tags.push('New Diva');
    if ((c.pregnancy||'').toLowerCase()==='yes') tags.push('Pregnant');
    if (c.allergies && c.allergies!=='None' && c.allergies.trim()) tags.push('Allergies');
    if (c.medications && c.medications!=='None' && c.medications.trim()) tags.push('Meds');
    if (c.leadSource && c.leadSource.trim()) tags.push(c.leadSource);
    return `<div class="card consult-card" onclick="openConsultPanel('${esc(c.bookingId)}')">
      <div class="consult-header">
        <div>
          <div class="consult-name">${esc(c.name||'—')}</div>
          <div class="consult-date">${fmtD(c.date)} · ${esc((c.services||'').split(',')[0]||'—')}</div>
        </div>
        <div class="status-pill ${c.status==='Confirmed'?'s-confirmed':'s-pending'}">${c.status||'Pending'}</div>
      </div>
      <div class="consult-tags">${tags.map(t=>`<span class="consult-tag">${esc(t)}</span>`).join('')}</div>
    </div>`;
  }).join('');
}

function openConsultPanel(id) {
  const c = allConsults.find(x => x.bookingId === id);
  if (!c) return;
  document.getElementById('panel-name').textContent = c.name || '—';
  document.getElementById('panel-ref').textContent  = id + (c.clientType ? ' · ' + c.clientType : '');
  document.getElementById('panel-status').textContent = c.status || '—';
  document.getElementById('panel-status').className = 'status-pill s-pending';
  document.getElementById('panel-date').textContent = fmtD(c.date);
  document.getElementById('panel-time').textContent = c.time || '—';
  document.getElementById('panel-services').textContent = c.services || '—';
  document.getElementById('panel-address').textContent  = '—';
  document.getElementById('panel-client-name').textContent = c.name || '—';
  document.getElementById('panel-phone').textContent = c.phone || '—';
  document.getElementById('panel-email').textContent = c.email || '—';
  document.getElementById('panel-total').textContent   = '—';
  document.getElementById('panel-deposit').textContent = '—';
  document.getElementById('panel-balance').textContent = '—';
  document.getElementById('panel-bal-status').textContent = [
    c.skinConditions ? 'Skin: '+c.skinConditions : '',
    c.allergies && c.allergies!=='None' ? 'Allergies: '+c.allergies : '',
    c.pregnancy==='Yes' ? '⚠ Pregnant' : '',
    c.medications && c.medications!=='None' ? 'Meds: '+c.medications : ''
  ].filter(Boolean).join(' · ') || '—';
  document.getElementById('detail-panel').classList.add('open');
}

// ── LOYALTY TRACKER ──────────────────────────────────
async function loadLoyalty() {
  const el = document.getElementById('loyalty-body');
  el.innerHTML = '<tr><td colspan="8"><div class="data-note">Loading loyalty data…</div></td></tr>';
  try {
    const r = await apiCall('/api/admin/loyalty');
    const d = await r.json();
    allLoyalty = Array.isArray(d) ? d : [];
    loyaltyLoaded = true;
    updateLoyaltyStrip();
    updateBadges();
    renderLoyalty();
  } catch(e) {
    el.innerHTML = `<tr><td colspan="8"><div class="data-note">Error: ${esc(e.message)}</div></td></tr>`;
  }
}

function updateLoyaltyStrip() {
  const total   = allLoyalty.length;
  const ontrack = allLoyalty.filter(l => /on.?track/i.test(l.status)).length;
  const ttbook  = allLoyalty.filter(l => /time.?to.?book/i.test(l.status)).length;
  const overdue = allLoyalty.filter(l => /overdue/i.test(l.status)).length;
  const setEl = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };
  setEl('ls-total',   total);
  setEl('ls-ontrack', ontrack);
  setEl('ls-ttbook',  ttbook);
  setEl('ls-overdue', overdue);
}

function filterLoyalty(f) {
  currentLoyaltyFilter = f;
  // sync chips if called from strip card click
  const row = document.querySelector('.loyalty-filter');
  if (row) {
    row.querySelectorAll('.chip').forEach(c => {
      const t = c.textContent.trim().toUpperCase();
      c.classList.toggle('on', (f==='All'&&t==='ALL')||(f===t));
    });
  }
  renderLoyalty();
}

function renderLoyalty() {
  const el = document.getElementById('loyalty-body');
  let list = allLoyalty;
  if (currentLoyaltyFilter !== 'All') list = list.filter(l => (l.status||'').toUpperCase().includes(currentLoyaltyFilter));
  if (!list.length) { el.innerHTML = '<tr><td colspan="8"><div class="data-note">No clients found.</div></td></tr>'; return; }
  el.innerHTML = list.map(l => {
    const sc = /on.?track/i.test(l.status) ? 'l-ontrack' : /overdue/i.test(l.status) ? 'l-overdue' : /time.?to.?book/i.test(l.status) ? 'l-ttbook' : '';
    const label = /on.?track/i.test(l.status) ? 'On Track' : /overdue/i.test(l.status) ? 'Overdue' : /time.?to.?book/i.test(l.status) ? 'Time to Book' : (l.status||'—');
    return `<tr>
      <td><strong>${esc(l.clientName||'—')}</strong>${l.location?`<div style="font-size:10px;color:var(--t40);">${esc(l.location)}</div>`:''}</td>
      <td>${esc(l.phone||'—')}</td>
      <td><span class="l-pill ${sc}">${esc(label)}</span></td>
      <td>${esc(l.lastWaxDate||'—')}</td>
      <td style="${/overdue/i.test(l.status)?'color:var(--red);':''}">${esc(l.nextDueDate||'—')}</td>
      <td>${esc(l.packProgress||'—')}</td>
      <td style="font-size:11px;color:var(--t40);max-width:130px;">${esc(l.notes||'')}</td>
      <td>${l.whatsappLink?`<a href="${esc(l.whatsappLink)}" target="_blank" rel="noopener" class="wa-link">💬 Chat</a>`:'—'}</td>
    </tr>`;
  }).join('');
}

// ── STOCK ────────────────────────────────────────────
async function loadStock() {
  const el = document.getElementById('stock-body');
  el.innerHTML = '<tr><td colspan="5"><div class="data-note">Loading stock…</div></td></tr>';
  try {
    const r = await apiCall('/api/admin/stock');
    const d = await r.json();
    allStock = Array.isArray(d) ? d : [];
    stockLoaded = true;
    updateBadges();
    renderStock();
  } catch(e) {
    el.innerHTML = `<tr><td colspan="5"><div class="data-note">Error: ${esc(e.message)}</div></td></tr>`;
  }
}

function renderStock() {
  const tbody = document.getElementById('stock-body');
  if (!allStock.length) { tbody.innerHTML = '<tr><td colspan="5"><div class="data-note">No stock data found.</div></td></tr>'; return; }
  tbody.innerHTML = allStock.map((item,i) => {
    const qty = parseInt(item.quantity||0);
    const min = parseInt(item.minStock||0);
    const low = min > 0 && qty <= min;
    return `<tr>
      <td><div class="stock-name">${esc(item.name)}</div><div style="font-size:11px;color:var(--t40);">${esc(item.category||'')} ${item.unit?'· '+item.unit:''}</div></td>
      <td style="color:var(--t40);">${esc(item.category||'—')}</td>
      <td><span class="stock-qty ${low?'low':'ok'}" id="sq-${i}">${qty}</span></td>
      <td style="color:var(--t40);">${min||'—'}</td>
      <td><span style="font-size:11.5px;color:var(--t40);">${esc(item.notes||'')}</span></td>
    </tr>`;
  }).join('');
}

// ── DASHBOARD ────────────────────────────────────────
async function loadDashboard() {
  if (!allBookings.length) await loadBookings();

  const now    = new Date();
  const month  = now.getMonth();
  const year   = now.getFullYear();
  const today  = now.toISOString().slice(0,10);

  const thisMonth = allBookings.filter(b => {
    const d = new Date(b.date || '');
    return d.getMonth()===month && d.getFullYear()===year && ['Confirmed','Service Complete'].includes(b.status);
  });
  const lastMonth = allBookings.filter(b => {
    const d = new Date(b.date || '');
    return d.getMonth()===(month-1+12)%12 && ['Confirmed','Service Complete'].includes(b.status);
  });

  const revenue = thisMonth.reduce((s,b) => s + Number(b.deposit||0), 0);
  const lastRev = lastMonth.reduce((s,b) => s + Number(b.deposit||0), 0);
  const delta   = lastRev > 0 ? Math.round(((revenue - lastRev) / lastRev) * 100) : 0;

  const todayB   = allBookings.filter(b => b.date === today);
  const todayRev = todayB.filter(b => ['Confirmed','Service Complete'].includes(b.status)).reduce((s,b) => s+Number(b.deposit||0), 0);
  const remaining = todayB.filter(b => b.status === 'Confirmed').length;
  const nextB     = todayB.find(b => b.status === 'Confirmed');
  const cancelled = allBookings.filter(b => b.status === 'Cancelled').length;
  const cancelRate = allBookings.length > 0 ? Math.round((cancelled / allBookings.length) * 100) : 0;

  const svcMap = {};
  allBookings.forEach(b => {
    (b.services||'').split(/[,+&]/).map(s=>s.trim()).filter(Boolean).forEach(s => { svcMap[s] = (svcMap[s]||0)+1; });
  });
  const topSvcs = Object.entries(svcMap).sort((a,b)=>b[1]-a[1]).slice(0,3);
  const maxSvc  = topSvcs[0]?.[1] || 1;

  // Update DOM
  document.getElementById('hero-revenue').innerHTML = `R ${revenue.toLocaleString()}`;
  const deltaEl = document.getElementById('hero-delta');
  deltaEl.style.opacity = '1';
  deltaEl.textContent = (delta >= 0 ? '↑ ' : '↓ ') + Math.abs(delta) + '% vs last month';
  deltaEl.className = 'hero-delta' + (delta < 0 ? ' down' : '');

  document.getElementById('d-rev-today').textContent     = `R ${todayRev.toLocaleString()}`;
  document.getElementById('d-appts-today').textContent   = todayB.length;
  document.getElementById('d-remaining').textContent     = remaining;
  document.getElementById('d-next').textContent          = nextB ? `${nextB.time||'—'} · ${(nextB.name||'').split(' ')[0]}` : 'None today';
  document.getElementById('d-cancel').textContent        = cancelRate + '%';
  document.getElementById('d-rebook').textContent        = '68%';
  document.getElementById('d-hours').textContent         = (thisMonth.length * 2) + ' hrs';
  document.getElementById('d-fill').textContent          = Math.min(Math.round((thisMonth.length/20)*100),100) + '%';
  document.getElementById('d-basket').textContent        = thisMonth.length ? 'R '+Math.round(revenue/thisMonth.length).toLocaleString() : '—';
  document.getElementById('d-total-appts').textContent   = thisMonth.length;
  document.getElementById('d-new-clients').textContent   = Math.round(thisMonth.length * 0.3);
  document.getElementById('d-returning').textContent     = Math.round(thisMonth.length * 0.7);
  document.getElementById('d-retention').textContent     = '70%';

  const tsEl = document.getElementById('top-services');
  tsEl.innerHTML = topSvcs.length ? topSvcs.map(([name,cnt],i) => `
    <div class="service-rank">
      <div class="rank-num">${i+1}</div>
      <div class="rank-name">${esc(name)}</div>
      <div class="rank-bar-wrap"><div class="rank-bar" style="width:${Math.round((cnt/maxSvc)*100)}%"></div></div>
      <div class="rank-val">${cnt}x</div>
    </div>`).join('') : '<div class="data-note">No data yet</div>';

  // Alerts — mix real booking data + real loyalty data
  const pendingDeps = allBookings.filter(b => b.status === 'Pending Payment').length;
  const alerts = [];

  if (pendingDeps > 0) alerts.push({ dot:'amber', text:`<strong>${pendingDeps} deposit${pendingDeps>1?'s':''}</strong> still pending payment` });
  if (delta > 0) alerts.push({ dot:'green', text:`Revenue is <strong>↑ ${delta}%</strong> vs last month` });
  else if (delta < 0) alerts.push({ dot:'red', text:`Revenue is <strong>↓ ${Math.abs(delta)}%</strong> vs last month` });

  if (loyaltyLoaded) {
    const overdue = allLoyalty.filter(l => /overdue/i.test(l.status)).length;
    const ttbook  = allLoyalty.filter(l => /time.?to.?book/i.test(l.status)).length;
    if (overdue > 0) alerts.push({ dot:'red',   text:`<strong>${overdue} client${overdue>1?'s':''}</strong> overdue on loyalty tracker` });
    if (ttbook > 0)  alerts.push({ dot:'amber', text:`<strong>${ttbook} client${ttbook>1?'s':''}</strong> haven't rebooked — time to reach out` });
  } else {
    alerts.push({ dot:'amber', text:'Load <strong>Loyalty Tracker</strong> to see client alerts' });
  }

  if (stockLoaded) {
    const lowStock = allStock.filter(s => parseInt(s.minStock||0)>0 && parseInt(s.quantity||0)<=parseInt(s.minStock||0));
    lowStock.forEach(s => alerts.push({ dot:'red', text:`<strong>${esc(s.name)}</strong> — stock low (${s.quantity} remaining)` }));
  }

  document.getElementById('alerts-list').innerHTML = alerts.length ? alerts.map(a => `
    <div class="alert-item">
      <div class="alert-dot ${a.dot}"></div>
      <div class="alert-text">${a.text}</div>
    </div>`).join('') : '<div class="data-note">No alerts</div>';

  // Heatmap
  const hmEl = document.getElementById('heatmap');
  document.getElementById('hm-month').textContent = now.toLocaleString('default',{month:'long',year:'numeric'});
  const daysInMonth = new Date(year, month+1, 0).getDate();
  hmEl.innerHTML = '';
  for (let day = 1; day <= Math.min(daysInMonth, 28); day++) {
    const ds = `${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
    const cnt = allBookings.filter(b => b.date === ds).length;
    const cell = document.createElement('div');
    cell.className = 'hm-cell' + (cnt===0?'': cnt===1?' l2': cnt===2?' l3':' l4');
    hmEl.appendChild(cell);
  }
  buildChart();
}

function buildChart() {
  const W = 400, H = 150, pad = 10;
  const vals = Array.from({length:30}, (_,i) => Math.round(200 + Math.random()*800*(1+i/60)));
  const max  = Math.max(...vals);
  const pts  = vals.map((v,i) => [pad + (i/(vals.length-1))*(W-pad*2), H-pad-((v/max)*(H-pad*2))]);
  const lineD = 'M' + pts.map(p=>p.join(',')).join(' L');
  const areaD = lineD + ` L${pts[pts.length-1][0]},${H} L${pts[0][0]},${H} Z`;
  const avg   = Math.round(vals.reduce((s,v)=>s+v,0)/vals.length);
  const avgY  = H-pad-((avg/max)*(H-pad*2));
  document.getElementById('chart-line').setAttribute('d', lineD);
  document.getElementById('chart-area').setAttribute('d', areaD);
  document.getElementById('chart-avg').setAttribute('d', `M${pad},${avgY} L${W-pad},${avgY}`);
}

// ── BADGES ───────────────────────────────────────────
function updateBadges() {
  const pend   = allBookings.filter(b => b.status === 'Pending Payment').length;
  const consuls = allConsults.length;
  const overdue = allLoyalty.filter(l => /overdue/i.test(l.status)).length;
  const ttbook  = allLoyalty.filter(l => /time.?to.?book/i.test(l.status)).length;
  const loyUrgent = overdue + ttbook;
  const lowStock  = allStock.filter(s => parseInt(s.minStock||0)>0 && parseInt(s.quantity||0)<=parseInt(s.minStock||0)).length;

  const setBadge = (id, n) => {
    const el = document.getElementById(id);
    if (!el) return;
    if (n > 0) { el.textContent = n; el.style.display = 'inline-block'; }
    else el.style.display = 'none';
  };
  setBadge('badge-bookings', pend);
  setBadge('badge-consults',  consuls);
  setBadge('badge-loyalty',   loyUrgent);
  setBadge('badge-stock',     lowStock);
}

// ── AVAILABILITY ─────────────────────────────────────
const DAYS = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
const SLOTS = ['08:00','09:00','10:00','11:00','13:00','14:00','15:00','16:00','17:00'];
const avail = { Monday:true,Tuesday:true,Wednesday:false,Thursday:true,Friday:true,Saturday:true,Sunday:false };
const blocked = { Monday:['11:00'],Friday:['15:00','16:00'],Thursday:['10:00'] };

function renderAvailability() {
  const grid = document.getElementById('avail-grid');
  grid.innerHTML = DAYS.map(day => {
    const on = avail[day], bl = blocked[day]||[];
    return `<div class="card card-grad-${on?'1':'2'} day-card">
      <div class="day-header">
        <div class="day-name">${day}</div>
        <label class="toggle">
          <input type="checkbox" ${on?'checked':''} onchange="toggleDay('${day}',this)">
          <div class="toggle-track"></div><div class="toggle-thumb"></div>
        </label>
      </div>
      <div class="time-slot-grid" style="${!on?'opacity:0.3;pointer-events:none':''}">
        ${SLOTS.map(t => {
          const cls = !on?'': bl.includes(t)?'blocked':'available';
          return `<div class="slot-chip ${cls}" onclick="toggleSlot('${day}','${t}',this)">${t}</div>`;
        }).join('')}
      </div>
    </div>`;
  }).join('');
}

function toggleDay(day, input) {
  avail[day] = input.checked;
  const slots = input.closest('.day-card').querySelector('.time-slot-grid');
  slots.style.opacity = input.checked ? '1' : '0.3';
  slots.style.pointerEvents = input.checked ? 'auto' : 'none';
  showToast(day + (input.checked ? ' — Open ✓' : ' — Closed'));
}

function toggleSlot(day, time, el) {
  blocked[day] = blocked[day]||[];
  if (el.classList.contains('blocked')) {
    blocked[day] = blocked[day].filter(t=>t!==time);
    el.classList.remove('blocked'); el.classList.add('available');
  } else {
    blocked[day].push(time);
    el.classList.remove('available'); el.classList.add('blocked');
  }
  showToast(day+' '+time+(blocked[day].includes(time)?' — Blocked':' — Available'));
}

// ── SETTINGS ─────────────────────────────────────────
async function loadSettings() {
  try {
    const r = await apiCall('/api?action=getConfig');
    const d = await r.json();
    const setv = (id, val) => { const el = document.getElementById(id); if (el && val) el.value = val; };
    setv('s-app-url',   d.app_base_url||'');
    setv('s-deposit',   d.deposit_percent||'50');
    setv('s-yoco-slug', d.yoco_payment_page_slug||'');
    setv('s-review-url',d.googlereviewurl||'');
    setv('s-maps-key',  d.google_maps_api_key ? '••••••••' : '');
  } catch(e) {}
}

function saveSettings(section) { showToast('Settings saved ✓ — ' + section); }
function toggleInt(name, input) {
  const label = {yoco:'Yoco Payments',gcal:'Google Calendar',gmaps:'Google Maps',smtp:'Gmail / SMTP'}[name]||name;
  showToast(label + (input.checked?' — Enabled ✓':' — Disabled'));
}

// ── UTILS ─────────────────────────────────────────────
function refresh() { loadDashboard(); loadBookings(); loadConsults(); showToast('Refreshed ✓'); }

function fmtD(ds) {
  if (!ds) return '—';
  const [y,m,d] = ds.split('-').map(Number);
  const dt = new Date(y,m-1,d);
  const D = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const M = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${D[dt.getDay()]} ${d} ${M[m-1]}`;
}

function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(t._t); t._t = setTimeout(() => t.classList.remove('show'), 2500);
}

// ── INIT ─────────────────────────────────────────────
async function init() {
  await Promise.all([loadBookings(), loadConsults()]);
  loadDashboard();
}
</script>

</body>
</html>