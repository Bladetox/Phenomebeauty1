          <span class="int-configure" onclick="show('settings',document.querySelector('[onclick*=settings]'))">Configure →</span>
        </div>
      </div>

      <!-- GOOGLE CALENDAR -->
      <div class="card card-grad-3 int-card gcal">
        <div class="int-header">
          <div style="display:flex;align-items:center;gap:14px;">
            <div class="int-icon">📅</div>
