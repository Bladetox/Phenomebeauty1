<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PhenomeBeauty — Admin</title>
<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}

:root {
  --black:  #000000;
  --bg:     #050508;
  --t100: rgba(255,255,255,0.96);
  --t80:  rgba(255,255,255,0.75);
  --t60:  rgba(255,255,255,0.55);
  --t40:  rgba(255,255,255,0.38);
  --t20:  rgba(255,255,255,0.18);
  --t10:  rgba(255,255,255,0.09);
  --t06:  rgba(255,255,255,0.06);
  --t03:  rgba(255,255,255,0.03);
  --card: rgba(255,255,255,0.055);
  --border: rgba(255,255,255,0.10);
  --border-hi: rgba(255,255,255,0.22);
  --green: #4ade80;
  --red:   #f87171;
  --amber: #fbbf24;
  --font-d: 'Cormorant Garamond', Georgia, serif;
  --font-b: 'Jost', system-ui, sans-serif;
}

html,body { height:100%; background:var(--bg); color:var(--t100); font-family:var(--font-b); -webkit-font-smoothing:antialiased; }
@media(min-width:641px){ html,body{ overflow:hidden; } }

.app { display:flex; height:100vh; }
@media(max-width:640px){ .app{ height:auto; min-height:100dvh; flex-direction:column; } }

/* ── LOGIN ── */
#pg-login {
  display:flex; align-items:center; justify-content:center;
  min-height:100dvh; padding:24px;
  background:var(--bg);
}
#pg-login.hidden { display:none; }
.login-card {
  width:100%; max-width:360px; padding:36px 30px;
  background:rgba(255,255,255,0.06); border:0.5px solid var(--border-hi);
  border-radius:24px; position:relative; overflow:hidden;
  box-shadow:0 32px 80px rgba(0,0,0,0.60);
}
.login-card::before {
  content:''; position:absolute; top:0; left:10%; right:10%; height:0.5px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.40) 50%,transparent);
}
.login-logo {
  width:52px; height:52px; border-radius:16px; overflow:hidden;
  border:0.5px solid var(--t20); margin:0 auto 20px; display:block;
}
.login-logo img { width:100%; height:100%; object-fit:cover; }
.login-title { font-family:var(--font-d); font-size:26px; font-weight:400; text-align:center; margin-bottom:4px; }
.login-sub { font-size:9px; font-weight:700; letter-spacing:0.22em; text-transform:uppercase; color:var(--t40); text-align:center; margin-bottom:28px; }
.login-label { display:block; font-size:9px; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; color:var(--t40); margin-bottom:6px; }
.login-input { width:100%; height:44px; padding:0 14px; background:var(--t06); border:0.5px solid var(--border); border-radius:11px; color:var(--t100); font-family:var(--font-b); font-size:14px; outline:none; transition:border-color 0.15s; }
.login-input:focus { border-color:var(--t40); }
.login-input::placeholder { color:var(--t20); }
.login-btn { width:100%; height:46px; margin-top:20px; background:var(--t100); color:var(--black); border:none; border-radius:11px; font-family:var(--font-b); font-size:13px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; transition:opacity 0.15s; display:flex; align-items:center; justify-content:center; gap:8px; }
.login-btn:hover { opacity:0.88; }
.login-btn:disabled { opacity:0.4; cursor:not-allowed; }
.login-err { margin-top:12px; font-size:11.5px; color:rgba(248,113,113,0.85); text-align:center; display:none; line-height:1.5; }
.login-spinner { width:16px; height:16px; border-radius:50%; border:2px solid rgba(0,0,0,0.15); border-top-color:var(--black); animation:lspin 0.7s linear infinite; }
@keyframes lspin { to { transform:rotate(360deg); } }

/* ── SIDEBAR ── */
.sidebar {
  width:64px; background:rgba(0,0,0,0.7);
  border-right:0.5px solid var(--border);
  display:flex; flex-direction:column; align-items:center;
  padding:16px 0; gap:2px; flex-shrink:0;
  backdrop-filter:blur(24px); z-index:10;
  position:relative;
}
.sidebar::after {
  content:''; position:absolute; top:0; right:0; bottom:0; width:0.5px;
  background:linear-gradient(to bottom, transparent, rgba(255,255,255,0.15) 30%, rgba(255,255,255,0.08) 70%, transparent);
}
@media(min-width:1024px){ .sidebar{width:220px;align-items:stretch;padding:16px 10px;} }

/* Mobile sidebar */
.sb-hamburger {
  display:none; width:36px; height:36px; border-radius:10px;
  background:var(--t06); border:0.5px solid var(--border);
  align-items:center; justify-content:center; cursor:pointer;
  font-size:18px; color:var(--t60); flex-shrink:0;
}
@media(max-width:640px){
  .sb-hamburger { display:flex; }
  .sidebar {
    position:fixed; top:0; left:0; bottom:0; z-index:200;
    transform:translateX(-100%); transition:transform 0.28s cubic-bezier(0.4,0,0.2,1);
    width:220px !important; align-items:stretch !important; padding:16px 10px !important;
  }
  .sidebar.mobile-open { transform:translateX(0); }
  .sidebar-brand { display:block !important; }
  .nav-lbl { display:block !important; }
  .nav-badge { display:inline-block !important; }
  .sb-overlay {
    display:none; position:fixed; inset:0; z-index:190;
    background:rgba(5,5,8,0.65); backdrop-filter:blur(4px);
  }
  .sb-overlay.show { display:block; }
  .app { flex-direction:column; height:auto; min-height:100dvh; }
  .main { overflow-y:auto; height:auto; }
  .topbar { position:sticky; top:0; }
  .detail-panel { width:100vw !important; }
}
.loyalty-strip {
  display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:16px;
}
@media(max-width:900px){ .loyalty-strip{ grid-template-columns:repeat(2,1fr); } }
@media(max-width:480px){ .loyalty-strip{ grid-template-columns:repeat(2,1fr); } }
.lstrip-card {
  padding:14px 12px; cursor:pointer; transition:border-color 0.15s;
}
.lstrip-card:hover { border-color:var(--border-hi); }
.lstrip-val { font-family:var(--font-d); font-size:28px; font-weight:300; color:var(--t100); line-height:1; }
.lstrip-val.green { color:var(--green); }
.lstrip-val.amber { color:var(--amber); }
.lstrip-val.red   { color:var(--red); }
.wa-link {
  display:inline-flex; align-items:center; gap:4px; padding:3px 10px;
  border-radius:99px; background:rgba(37,211,102,0.10); border:0.5px solid rgba(37,211,102,0.22);
  color:rgba(37,211,102,0.85); font-size:10px; font-weight:700; text-decoration:none; transition:all 0.14s;
}
.wa-link:hover { background:rgba(37,211,102,0.20); }
.loyalty-filter { display:flex; gap:7px; flex-wrap:wrap; margin-bottom:14px; }
.loyalty-table { width:100%; border-collapse:collapse; min-width:540px; }
.loyalty-table th { text-align:left; padding:9px 12px; font-size:9px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:var(--t40); border-bottom:0.5px solid var(--border); white-space:nowrap; }
.loyalty-table td { padding:11px 12px; font-size:12px; color:var(--t80); border-bottom:0.5px solid var(--t06); vertical-align:middle; }
.loyalty-table tr:last-child td { border-bottom:none; }
.loyalty-table tr:hover td { background:rgba(255,255,255,0.02); }
.l-ontrack { background:rgba(74,222,128,0.10); color:var(--green); border:0.5px solid rgba(74,222,128,0.22); }
.l-overdue { background:rgba(248,113,113,0.10); color:var(--red); border:0.5px solid rgba(248,113,113,0.22); }
.l-ttbook  { background:rgba(251,191,36,0.10); color:var(--amber); border:0.5px solid rgba(251,191,36,0.22); }
.l-pill { font-size:9.5px; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; padding:3px 9px; border-radius:99px; white-space:nowrap; }

.sidebar-logo-wrap {
  display:flex; align-items:center; gap:10px;
  padding:0 8px; margin-bottom:28px; width:100%;
}
.sidebar-logo {
  width:38px; height:38px; border-radius:12px; overflow:hidden;
  border:0.5px solid var(--t20); flex-shrink:0;
}
.sidebar-logo img { width:100%; height:100%; object-fit:cover; }
.sidebar-brand { font-family:var(--font-d); font-size:15px; font-weight:400; color:var(--t60); letter-spacing:0.04em; display:none; }
@media(min-width:1024px){ .sidebar-brand{display:block;} }

.nav-item {
  display:flex; align-items:center; justify-content:center; gap:10px;
  padding:11px; border-radius:13px; cursor:pointer; color:var(--t40);
  font-size:13px; font-weight:500; transition:all 0.15s ease;
  white-space:nowrap; position:relative; width:100%;
}
@media(min-width:1024px){ .nav-item{justify-content:flex-start;padding:11px 12px;} }
.nav-item:hover { background:var(--t06); color:var(--t80); }
.nav-item.active { background:var(--t10); color:var(--t100); }
.nav-item.active::before {
  content:''; position:absolute; left:0; top:20%; bottom:20%;
  width:2px; border-radius:99px; background:var(--t100);
}
.nav-icon { font-size:17px; flex-shrink:0; }
.nav-lbl { display:none; }
@media(min-width:1024px){ .nav-lbl{display:block;} }
.nav-badge {
  margin-left:auto; background:var(--t100); color:var(--black);
  font-size:9px; font-weight:800; padding:2px 6px;
  border-radius:99px; min-width:18px; text-align:center;
}
.sidebar-spacer { flex:1; }

/* ── MAIN ── */
.main { flex:1; overflow-y:auto; overflow-x:hidden; scrollbar-width:thin; scrollbar-color:var(--t10) transparent; }
.main::-webkit-scrollbar{width:4px;}
.main::-webkit-scrollbar-thumb{background:var(--t10);border-radius:99px;}

/* ── TOPBAR ── */
.topbar {
  position:sticky; top:0; z-index:20; height:56px;
  background:rgba(5,5,8,0.92); border-bottom:0.5px solid var(--border);
  backdrop-filter:blur(24px); display:flex; align-items:center;
  padding:0 20px; gap:10px;
}
.topbar-title { font-family:var(--font-d); font-size:20px; font-weight:400; color:var(--t100); flex:1; }
.search-bar {
  height:34px; padding:0 14px; background:var(--t06);
  border:0.5px solid var(--border); border-radius:99px;
  color:var(--t80); font-family:var(--font-b); font-size:12px;
  outline:none; width:180px;
}
.search-bar::placeholder{color:var(--t40);}
.tbtn {
  height:34px; padding:0 14px; background:var(--t06);
  border:0.5px solid var(--border); border-radius:99px;
  color:var(--t60); font-family:var(--font-b); font-size:12px;
  font-weight:500; cursor:pointer; transition:all 0.15s ease; white-space:nowrap;
}
.tbtn:hover{color:var(--t100);border-color:var(--t40);}

/* ── VIEWS ── */
.view{display:none;padding:20px;}
.view.active{display:block;}

/* ── BASE CARD ── */
.card {
  background:var(--card); border:0.5px solid var(--border);
  border-radius:20px; position:relative; overflow:hidden;
}
.card::before {
  content:''; position:absolute; top:0; left:10%; right:10%; height:0.5px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.18) 50%,transparent);
}

/* Gradient card variants */
.card-grad-1 {
  background:linear-gradient(135deg, rgba(255,255,255,0.09) 0%, rgba(255,255,255,0.04) 60%, rgba(255,255,255,0.07) 100%);
}
.card-grad-2 {
  background:linear-gradient(135deg, rgba(255,255,255,0.07) 0%, rgba(255,255,255,0.03) 50%, rgba(255,255,255,0.08) 100%);
}
.card-grad-3 {
  background:linear-gradient(160deg, rgba(74,222,128,0.06) 0%, rgba(255,255,255,0.04) 60%);
}
.card-grad-4 {
  background:linear-gradient(160deg, rgba(248,113,113,0.05) 0%, rgba(255,255,255,0.04) 60%);
}
.card-grad-5 {
  background:linear-gradient(135deg, rgba(251,191,36,0.06) 0%, rgba(255,255,255,0.04) 60%);
}

.label-caps { font-size:9.5px; font-weight:700; letter-spacing:0.20em; text-transform:uppercase; color:var(--t40); }

/* ═══════════════════════════════
   DASHBOARD
═══════════════════════════════ */
/* HERO */
.hero-card {
  padding:28px 28px 24px; margin-bottom:16px;
  border-radius:24px; position:relative; overflow:hidden;
  display:grid; grid-template-columns:1fr auto; gap:20px; align-items:center;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.11) 0%, rgba(255,255,255,0.04) 50%, rgba(255,255,255,0.08) 100%);
  border:0.5px solid rgba(255,255,255,0.16);
}
.hero-card::before {
  content:''; position:absolute; top:0; left:10%; right:10%; height:0.5px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.40) 50%,transparent);
}
.hero-card::after {
  content:''; position:absolute; inset:0; pointer-events:none;
  background:radial-gradient(ellipse at 0% 0%, rgba(255,255,255,0.06) 0%, transparent 65%);
}

.hero-revenue {
  font-family:var(--font-d); font-size:56px; font-weight:300;
  color:var(--t100); line-height:1; letter-spacing:-0.02em; margin-bottom:10px;
}
.hero-delta {
  display:inline-flex; align-items:center; gap:6px;
  padding:4px 12px; border-radius:99px; font-size:11px; font-weight:600;
  background:rgba(74,222,128,0.12); border:0.5px solid rgba(74,222,128,0.25);
  color:var(--green); margin-bottom:18px;
}
.hero-delta.down { background:rgba(248,113,113,0.12); border-color:rgba(248,113,113,0.25); color:var(--red); }
.hero-cta {
  height:40px; padding:0 22px; background:var(--t100); color:var(--black);
  border:none; border-radius:99px; font-family:var(--font-b); font-size:12px;
  font-weight:700; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer;
}
.hero-cta:hover{opacity:0.88;}

/* Heatmap */
.heatmap { display:grid; grid-template-columns:repeat(7,1fr); gap:3px; width:154px; }
.hm-cell { aspect-ratio:1; border-radius:3px; background:var(--t06); }
.hm-cell.l1{background:rgba(255,255,255,0.12);}
.hm-cell.l2{background:rgba(255,255,255,0.28);}
.hm-cell.l3{background:rgba(255,255,255,0.52);}
.hm-cell.l4{background:rgba(255,255,255,0.82);}

/* Loading skeleton */
.skeleton {
  background:linear-gradient(90deg, var(--t06) 25%, var(--t10) 50%, var(--t06) 75%);
  background-size:200% 100%;
  animation:shimmer 1.5s infinite;
  border-radius:6px; color:transparent; user-select:none;
}
@keyframes shimmer { 0%{background-position:200% 0;} 100%{background-position:-200% 0;} }

/* Dashboard grid */
.dash-grid {
  display:grid; grid-template-columns:1fr; gap:14px;
}
@media(min-width:900px){ .dash-grid{grid-template-columns:260px 1fr 260px;} }

.left-col,.right-col{display:flex;flex-direction:column;gap:12px;}

.metric-card{padding:18px 20px;}
.metric-title {
  font-family:var(--font-d); font-size:17px; font-weight:400;
  color:var(--t80); margin-bottom:14px;
}
.metric-row {
  display:flex; align-items:center; justify-content:space-between;
  padding:8px 0; border-bottom:0.5px solid var(--t06);
}
.metric-row:last-child{border-bottom:none;padding-bottom:0;}
.metric-key{font-size:11.5px;color:var(--t40);font-weight:500;}
.metric-val{font-family:var(--font-d);font-size:17px;font-weight:400;color:var(--t100);}
.metric-val.green{color:var(--green);}
.metric-val.red{color:var(--red);}
.metric-val.amber{color:var(--amber);}
.metric-val.sm{font-family:var(--font-b);font-size:13px;font-weight:500;}

/* Chart */
.chart-card{padding:22px;}
.chart-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
.chart-title{font-family:var(--font-d);font-size:20px;font-weight:400;color:var(--t100);}
.chart-area{height:150px;position:relative;margin-bottom:14px;}
.chart-svg{width:100%;height:100%;}
.chart-footer{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding-top:14px;border-top:0.5px solid var(--t06);}
.chart-stat-label{font-size:9.5px;color:var(--t40);font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:4px;}
.chart-stat-val{font-family:var(--font-d);font-size:26px;font-weight:300;color:var(--t100);}

/* Services ranking */
.service-rank{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:0.5px solid var(--t06);}
.service-rank:last-child{border-bottom:none;}
.rank-num{font-family:var(--font-d);font-size:20px;font-weight:300;color:var(--t20);width:24px;flex-shrink:0;}
.rank-name{flex:1;font-size:12.5px;font-weight:500;color:var(--t80);}
.rank-bar-wrap{width:52px;height:2px;background:var(--t06);border-radius:99px;overflow:hidden;}
.rank-bar{height:100%;background:var(--t60);border-radius:99px;}
.rank-val{font-size:11px;color:var(--t40);font-weight:600;width:28px;text-align:right;}

/* Alerts */
.alert-item{display:flex;align-items:flex-start;gap:10px;padding:9px 12px;border-radius:11px;border:0.5px solid var(--border);background:var(--t06);margin-bottom:7px;}
.alert-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.alert-dot.red{background:var(--red);box-shadow:0 0 6px var(--red);}
.alert-dot.amber{background:var(--amber);box-shadow:0 0 6px var(--amber);}
.alert-dot.green{background:var(--green);box-shadow:0 0 5px var(--green);}
.alert-text{font-size:11.5px;color:var(--t60);line-height:1.55;}
.alert-text strong{color:var(--t100);font-weight:600;}

/* ═══════════════════════════════
   BOOKINGS
═══════════════════════════════ */
.filter-row{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:14px;}
.chip{height:30px;padding:0 13px;border-radius:99px;font-size:11.5px;font-weight:600;border:0.5px solid var(--border);background:var(--t06);color:var(--t40);cursor:pointer;transition:all 0.15s ease;white-space:nowrap;}
.chip.on,.chip:hover{background:var(--t100);color:var(--black);border-color:transparent;}

.booking-list{display:flex;flex-direction:column;gap:7px;}
.booking-row {
  display:grid; grid-template-columns:40px 1fr auto auto;
  align-items:center; gap:12px; padding:13px 16px;
  border-radius:16px; cursor:pointer; transition:all 0.15s ease;
}
.booking-row:hover{background:var(--t06);border-color:var(--border-hi);}
.booking-avatar{width:38px;height:38px;border-radius:12px;background:var(--t10);border:0.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:var(--font-d);font-size:18px;color:var(--t60);}
.booking-name{font-size:13.5px;font-weight:600;color:var(--t100);margin-bottom:2px;}
.booking-meta{font-size:11px;color:var(--t40);}
.booking-amount{font-family:var(--font-d);font-size:16px;font-weight:400;color:var(--t80);text-align:right;white-space:nowrap;}
.status-pill{font-size:9.5px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;padding:3px 9px;border-radius:99px;white-space:nowrap;}
.s-pending{background:rgba(251,191,36,0.12);color:var(--amber);border:0.5px solid rgba(251,191,36,0.25);}
.s-confirmed{background:rgba(74,222,128,0.10);color:var(--green);border:0.5px solid rgba(74,222,128,0.22);}
.s-complete{background:rgba(255,255,255,0.07);color:var(--t60);border:0.5px solid var(--border);}
.s-cancelled{background:rgba(248,113,113,0.10);color:var(--red);border:0.5px solid rgba(248,113,113,0.22);}

/* booking detail panel */
.detail-panel {
  position:fixed; top:0; right:0; bottom:0; width:360px;
  background:rgba(5,5,8,0.97); border-left:0.5px solid var(--border);
  backdrop-filter:blur(32px); z-index:50; padding:24px 22px;
  transform:translateX(100%); transition:transform 0.3s cubic-bezier(0.4,0,0.2,1);
  overflow-y:auto;
}
.detail-panel.open{transform:translateX(0);}
.panel-close{position:absolute;top:18px;right:18px;width:32px;height:32px;border-radius:50%;background:var(--t06);border:0.5px solid var(--border);color:var(--t60);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;}
.panel-title{font-family:var(--font-d);font-size:24px;font-weight:400;color:var(--t100);margin-bottom:4px;}
.panel-sub{font-size:11.5px;color:var(--t40);margin-bottom:22px;}
.panel-section{margin-bottom:18px;}
.panel-section-title{font-size:9.5px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--t40);margin-bottom:10px;}
.panel-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:0.5px solid var(--t06);}
.panel-row:last-child{border-bottom:none;}
.panel-key{font-size:11.5px;color:var(--t40);}
.panel-val{font-size:13px;color:var(--t100);font-weight:500;text-align:right;}
.action-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:20px;}
.action-btn{height:40px;border-radius:12px;font-family:var(--font-b);font-size:12px;font-weight:600;cursor:pointer;border:0.5px solid var(--border);background:var(--t06);color:var(--t80);transition:all 0.15s ease;}
.action-btn:hover{background:var(--t10);color:var(--t100);}
.action-btn.primary{background:var(--t100);color:var(--black);border-color:transparent;grid-column:1/-1;}
.action-btn.danger{border-color:rgba(248,113,113,0.30);color:var(--red);}

/* ═══════════════════════════════
   AVAILABILITY
═══════════════════════════════ */
.avail-grid{display:grid;grid-template-columns:1fr;gap:14px;}
@media(min-width:768px){.avail-grid{grid-template-columns:1fr 1fr;}}
.day-card{padding:18px 20px;}
.day-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.day-name{font-family:var(--font-d);font-size:20px;font-weight:400;color:var(--t100);}
.toggle{position:relative;width:44px;height:24px;cursor:pointer;flex-shrink:0;}
.toggle input{opacity:0;width:0;height:0;position:absolute;}
.toggle-track{position:absolute;inset:0;border-radius:99px;background:var(--t10);border:0.5px solid var(--border);transition:all 0.2s ease;}
.toggle-thumb{position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:var(--t40);transition:all 0.2s ease;}
.toggle input:checked+.toggle-track{background:var(--t100);border-color:var(--t100);}
.toggle input:checked~.toggle-thumb{left:23px;background:var(--black);}
.time-slot-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;}
.slot-chip{padding:7px 0;border-radius:10px;text-align:center;font-size:11px;font-weight:600;cursor:pointer;border:0.5px solid var(--border);background:var(--t06);color:var(--t40);transition:all 0.15s ease;}
.slot-chip.available{border-color:rgba(74,222,128,0.30);background:rgba(74,222,128,0.07);color:var(--green);}
.slot-chip.blocked{border-color:rgba(248,113,113,0.25);background:rgba(248,113,113,0.06);color:var(--red);text-decoration:line-through;}

/* ═══════════════════════════════
   STOCK
═══════════════════════════════ */
.stock-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.add-btn{height:36px;padding:0 18px;background:var(--t100);color:var(--black);border:none;border-radius:99px;font-family:var(--font-b);font-size:12px;font-weight:700;cursor:pointer;letter-spacing:0.04em;}
.stock-table{width:100%;border-collapse:collapse;}
.stock-table th{text-align:left;padding:10px 14px;font-size:9.5px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--t40);border-bottom:0.5px solid var(--border);}
.stock-table td{padding:12px 14px;font-size:13px;color:var(--t80);border-bottom:0.5px solid var(--t06);vertical-align:middle;}
.stock-table tr:last-child td{border-bottom:none;}
.stock-table tr:hover td{background:rgba(255,255,255,0.02);}
.stock-name{font-weight:600;color:var(--t100);}
.stock-qty{font-family:var(--font-d);font-size:19px;font-weight:400;}
.stock-qty.low{color:var(--red);}
.stock-qty.ok{color:var(--green);}
.sact{width:28px;height:28px;border-radius:8px;background:var(--t06);border:0.5px solid var(--border);color:var(--t60);cursor:pointer;font-size:14px;display:inline-flex;align-items:center;justify-content:center;transition:all 0.15s;}
.sact:hover{background:var(--t10);color:var(--t100);}

/* ═══════════════════════════════
   SETTINGS
═══════════════════════════════ */
.settings-grid{display:grid;grid-template-columns:1fr;gap:14px;}
@media(min-width:768px){.settings-grid{grid-template-columns:1fr 1fr;}}
.settings-card{padding:22px;}
.settings-title{font-family:var(--font-d);font-size:18px;font-weight:400;color:var(--t80);margin-bottom:16px;padding-bottom:12px;border-bottom:0.5px solid var(--t06);}
.setting-row{margin-bottom:13px;}
.setting-label{display:block;font-size:9.5px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;color:var(--t40);margin-bottom:6px;}
.setting-input{width:100%;height:42px;padding:0 13px;background:var(--t06);border:0.5px solid var(--border);border-radius:11px;color:var(--t100);font-family:var(--font-b);font-size:13px;outline:none;transition:border-color 0.15s;}
.setting-input:focus{border-color:var(--t40);}
.setting-input::placeholder{color:var(--t20);}
.save-btn{height:40px;padding:0 22px;background:var(--t100);color:var(--black);border:none;border-radius:99px;font-family:var(--font-b);font-size:12px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;cursor:pointer;margin-top:4px;}
.save-btn:hover{opacity:0.88;}

/* ═══════════════════════════════
   INTEGRATIONS
═══════════════════════════════ */
.integrations-grid{display:grid;grid-template-columns:1fr;gap:14px;}
@media(min-width:768px){.integrations-grid{grid-template-columns:1fr 1fr;}}

.int-card {
  padding:22px; position:relative; overflow:hidden;
}

.int-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;}
.int-icon{width:44px;height:44px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;border:0.5px solid var(--border);background:var(--t06);flex-shrink:0;}
.int-name{font-family:var(--font-d);font-size:20px;font-weight:400;color:var(--t100);margin-bottom:3px;}
.int-desc{font-size:12px;color:var(--t40);line-height:1.6;}
.int-status{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:600;margin-top:10px;}
.int-dot{width:6px;height:6px;border-radius:50%;}
.int-dot.live{background:var(--green);box-shadow:0 0 6px var(--green);}
.int-dot.off{background:var(--t20);}
.int-dot.error{background:var(--red);box-shadow:0 0 6px var(--red);}

.int-features{margin:14px 0;display:flex;flex-direction:column;gap:6px;}
.int-feature{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--t60);}
.int-feature::before{content:'✓';color:var(--green);font-size:11px;font-weight:700;}

.int-footer{display:flex;align-items:center;justify-content:space-between;margin-top:16px;padding-top:14px;border-top:0.5px solid var(--t06);}
.int-configure{font-size:11.5px;color:var(--t40);cursor:pointer;text-decoration:underline;text-underline-offset:3px;}
.int-configure:hover{color:var(--t80);}

/* Big toggle for integrations */
.int-toggle{position:relative;width:52px;height:28px;cursor:pointer;flex-shrink:0;}
.int-toggle input{opacity:0;width:0;height:0;position:absolute;}
.int-toggle-track{position:absolute;inset:0;border-radius:99px;background:var(--t10);border:0.5px solid var(--border);transition:all 0.25s ease;}
.int-toggle-thumb{position:absolute;top:4px;left:4px;width:20px;height:20px;border-radius:50%;background:var(--t40);transition:all 0.25s ease;}
.int-toggle input:checked+.int-toggle-track{background:var(--green);border-color:var(--green);}
.int-toggle input:checked~.int-toggle-thumb{left:28px;background:var(--black);}

/* Glow accents on integration cards */
.int-card.yoco::after{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;background:rgba(37,99,235,0.08);pointer-events:none;}
.int-card.gcal::after{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;background:rgba(74,222,128,0.06);pointer-events:none;}
.int-card.gmaps::after{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;background:rgba(251,191,36,0.06);pointer-events:none;}
.int-card.smtp::after{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;background:rgba(255,255,255,0.04);pointer-events:none;}
.int-card.gsheets::after{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;background:rgba(74,222,128,0.05);pointer-events:none;}
.int-card.gsa::after{content:'';position:absolute;top:-30px;right:-30px;width:100px;height:100px;border-radius:50%;background:rgba(255,255,255,0.04);pointer-events:none;}

/* ── CONSULTATIONS ── */
.consult-card{padding:18px 20px;margin-bottom:9px;cursor:pointer;transition:all 0.15s ease;}
.consult-card:hover{border-color:var(--border-hi);}
.consult-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;}
.consult-name{font-family:var(--font-d);font-size:20px;font-weight:400;color:var(--t100);margin-bottom:3px;}
.consult-date{font-size:11px;color:var(--t40);}
.consult-tags{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px;}
.consult-tag{font-size:9.5px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:3px 9px;border-radius:99px;border:0.5px solid var(--border);background:var(--t06);color:var(--t40);}

/* ── DATA LOADING STATES ── */
.data-note{font-size:11px;color:var(--t40);text-align:center;padding:32px 0;font-style:italic;}

/* ── TOAST ── */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--t100);color:var(--black);padding:10px 20px;border-radius:99px;font-size:13px;font-weight:600;transition:transform 0.25s cubic-bezier(0.34,1.56,0.64,1);z-index:999;white-space:nowrap;}
.toast.show{transform:translateX(-50%) translateY(0);}

/* ── MOBILE REFINEMENTS ───────────────────────────── */

/* Phones and small devices */
@media (max-width: 640px) {

  /* General spacing */
  .view {
    padding: 14px 12px;
  }

  /* Topbar: make it fit, hide duplicate Sign out button */
  .topbar {
    padding: 0 12px;
    gap: 6px;
  }

  .search-bar {
    flex: 1;
    width: auto;
    min-width: 0;
  }

  .tbtn {
    padding: 0 10px;
    font-size: 11px;
  }

  /* Hide topbar Sign out on mobile (sidebar already has Sign Out) */
  .topbar .tbtn:last-child {
    display: none;
  }

  /* Hero card: stack instead of side‑by‑side */
  .hero-card {
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .hero-card > div:last-child {
    margin-top: 4px;
  }

  /* Chart: slightly tighter padding */
  .chart-card {
    padding: 16px 14px;
  }

  /* Booking rows: avoid 4 cramped columns */
  .booking-row {
    grid-template-columns: 40px 1fr;
    grid-template-rows: auto auto;
    align-items: flex-start;
    gap: 8px 10px;
  }

  .booking-amount {
    justify-self: flex-start;
    font-size: 14px;
  }

  .booking-row .status-pill {
    justify-self: flex-start;
    margin-top: 2px;
  }

  /* Detail panel: full‑width on mobile */
  .detail-panel {
    width: 100vw;
    max-width: 100%;
  }

  /* Settings & integrations: single column */
  .settings-grid,
  .integrations-grid {
    grid-template-columns: 1fr;
  }
}

/* Extra small screens: loyalty header tiles stack */
@media (max-width: 420px) {
  .loyalty-strip {
    grid-template-columns: 1fr;
  }
}

/* Slightly softer padding on mobile cards */
@media (max-width: 640px) {
  .metric-card,
  .int-card,
  .settings-card,
  .day-card,
  .consult-card {
    padding: 14px 14px;
  }
}

</style>
</head>
<body>

<!-- ══ LOGIN ══ -->
<div id="pg-login">
  <div class="login-card">
    <div class="login-logo"><img src="https://iili.io/fpiAjBj.jpg" alt="PB"></div>
    <h1 class="login-title">Admin Portal</h1>
    <p class="login-sub">PhenomeBeauty Studio</p>
    <div>
      <label class="login-label" for="l-pass">Password</label>
      <input type="password" id="l-pass" class="login-input" placeholder="Enter admin password"
             onkeydown="if(event.key==='Enter')doLogin()">
    </div>
    <button class="login-btn" id="l-btn" onclick="doLogin()">Sign In</button>
    <div class="login-err" id="l-err"></div>
  </div>
</div>

<!-- ══ APP ══ -->
<div class="app" id="pg-app" style="display:none;">

<!-- Mobile sidebar overlay -->
<div class="sb-overlay" id="sb-overlay" onclick="closeSidebar()"></div>

<!-- ── SIDEBAR ── -->
<aside class="sidebar">
  <div class="sidebar-logo-wrap">
    <div class="sidebar-logo"><img src="https://iili.io/fpiAjBj.jpg" alt="PB"></div>
    <span class="sidebar-brand">PhenomeBeauty</span>
  </div>
  <div class="nav-item active" onclick="show('dashboard',this)"><span class="nav-icon">◈</span><span class="nav-lbl">Dashboard</span></div>
  <div class="nav-item" onclick="show('bookings',this)"><span class="nav-icon">◷</span><span class="nav-lbl">Bookings</span><span class="nav-badge nav-lbl" id="badge-bookings" style="display:none;"></span></div>
  <div class="nav-item" onclick="show('consults',this)"><span class="nav-icon">✦</span><span class="nav-lbl">New Divas</span><span class="nav-badge nav-lbl" id="badge-consults" style="display:none;"></span></div>
  <div class="nav-item" onclick="show('loyalty',this)"><span class="nav-icon">♡</span><span class="nav-lbl">Loyalty Tracker</span><span class="nav-badge nav-lbl" id="badge-loyalty" style="display:none;"></span></div>
  <div class="nav-item" onclick="show('availability',this)"><span class="nav-icon">⊡</span><span class="nav-lbl">Availability</span></div>
  <div class="nav-item" onclick="show('stock',this)"><span class="nav-icon">◫</span><span class="nav-lbl">Stock</span><span class="nav-badge nav-lbl" id="badge-stock" style="display:none;"></span></div>
  <div class="sidebar-spacer"></div>
  <div class="nav-item" onclick="show('integrations',this)"><span class="nav-icon">⟡</span><span class="nav-lbl">Integrations</span></div>
  <div class="nav-item" onclick="show('settings',this)"><span class="nav-icon">⊙</span><span class="nav-lbl">Settings</span></div>
  <div class="nav-item" onclick="doLogout()" style="margin-top:4px;"><span class="nav-icon">↩</span><span class="nav-lbl">Sign Out</span></div>
</aside>

<!-- ── MAIN ── -->
<div class="main">
  <div class="topbar">
    <div class="sb-hamburger" onclick="openSidebar()">☰</div>
    <div class="topbar-title" id="topbar-title">Dashboard</div>
    <input class="search-bar" placeholder="🔍  Search…" oninput="searchBookings(this.value)">
    <button class="tbtn" onclick="refresh()">↻ Refresh</button>
    <button class="tbtn" onclick="doLogout()">Sign out</button>
  </div>

  <!-- ═══ DASHBOARD ═══ -->
  <div class="view active" id="view-dashboard">
    <div class="hero-card">
      <div>
        <div class="label-caps" style="margin-bottom:8px;">This Month's Performance</div>
        <div class="hero-revenue" id="hero-revenue">
          <span class="skeleton" style="display:inline-block;width:160px;height:52px;border-radius:8px;">R 0</span>
        </div>
        <div class="hero-delta" id="hero-delta" style="opacity:0;">↑ 0%</div>
        <button class="hero-cta" onclick="showToast('Report coming soon')">View Detailed Report</button>
      </div>
      <div>
        <div class="label-caps" style="margin-bottom:10px;text-align:center;" id="hm-month">Loading…</div>
        <div class="heatmap" id="heatmap"></div>
      </div>
    </div>

    <div class="dash-grid">
      <!-- LEFT -->
      <div class="left-col">
        <div class="card card-grad-1 metric-card">
          <div class="metric-title">Today's Overview</div>
          <div class="metric-row"><span class="metric-key">Revenue Today</span><span class="metric-val" id="d-rev-today">—</span></div>
          <div class="metric-row"><span class="metric-key">Appointments</span><span class="metric-val" id="d-appts-today">—</span></div>
          <div class="metric-row"><span class="metric-key">Remaining</span><span class="metric-val amber" id="d-remaining">—</span></div>
          <div class="metric-row"><span class="metric-key">Next Appointment</span><span class="metric-val sm" id="d-next">—</span></div>
        </div>
        <div class="card card-grad-3 metric-card">
          <div class="metric-title">Booking Health</div>
          <div class="metric-row"><span class="metric-key">Rebooking Rate</span><span class="metric-val green" id="d-rebook">—</span></div>
          <div class="metric-row"><span class="metric-key">Cancellation Rate</span><span class="metric-val red" id="d-cancel">—</span></div>
        </div>
        <div class="card card-grad-2 metric-card">
          <div class="metric-title">Utilisation</div>
          <div class="metric-row"><span class="metric-key">Booked Hours</span><span class="metric-val" id="d-hours">—</span></div>
          <div class="metric-row"><span class="metric-key">Fill Rate</span><span class="metric-val green" id="d-fill">—</span></div>
        </div>
      </div>

      <!-- CENTER -->
      <div class="card chart-card" style="background:linear-gradient(160deg,rgba(255,255,255,0.07) 0%,rgba(255,255,255,0.03) 60%,rgba(255,255,255,0.06) 100%);">
        <div class="chart-header">
          <div class="chart-title">Revenue Trend</div>
          <div class="label-caps">Last 30 days</div>
        </div>
        <div class="chart-area">
          <svg class="chart-svg" id="chart-svg" viewBox="0 0 400 150" preserveAspectRatio="none">
            <defs>
              <linearGradient id="g1" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="rgba(255,255,255,0.14)"/>
                <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
              </linearGradient>
            </defs>
            <line x1="0" y1="37" x2="400" y2="37" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
            <line x1="0" y1="75" x2="400" y2="75" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
            <line x1="0" y1="112" x2="400" y2="112" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
            <path id="chart-area" d="" fill="url(#g1)"/>
            <path id="chart-line" d="" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path id="chart-avg" d="" fill="none" stroke="rgba(255,255,255,0.22)" stroke-width="1" stroke-dasharray="4,4" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="chart-footer">
          <div><div class="chart-stat-label">Avg Basket Value</div><div class="chart-stat-val" id="d-basket">—</div></div>
          <div><div class="chart-stat-label">Total Appointments</div><div class="chart-stat-val" id="d-total-appts">—</div></div>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="right-col">
        <div class="card card-grad-2 metric-card">
          <div class="metric-title">Clients This Month</div>
          <div class="metric-row"><span class="metric-key">New Clients</span><span class="metric-val" id="d-new-clients">—</span></div>
          <div class="metric-row"><span class="metric-key">Returning</span><span class="metric-val" id="d-returning">—</span></div>
          <div class="metric-row"><span class="metric-key">Retention Rate</span><span class="metric-val green" id="d-retention">—</span></div>
        </div>
        <div class="card card-grad-1 metric-card">
          <div class="metric-title">Top Services</div>
          <div id="top-services"><div class="data-note">Loading…</div></div>
        </div>
        <div class="card card-grad-4 metric-card">
          <div class="metric-title">Alerts</div>
          <div id="alerts-list"><div class="data-note">Loading…</div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ BOOKINGS ═══ -->
  <div class="view" id="view-bookings">
    <div class="filter-row">
      <div class="chip on" onclick="fc(this);filterBookings('All')">All</div>
      <div class="chip" onclick="fc(this);filterBookings('Today')">Today</div>
      <div class="chip" onclick="fc(this);filterBookings('Pending Payment')">Pending</div>
      <div class="chip" onclick="fc(this);filterBookings('Confirmed')">Confirmed</div>
      <div class="chip" onclick="fc(this);filterBookings('Service Complete')">Complete</div>
      <div class="chip" onclick="fc(this);filterBookings('Cancelled')">Cancelled</div>
    </div>
    <div class="booking-list" id="booking-list">
      <div class="data-note">Loading bookings…</div>
    </div>
  </div>

  <!-- ═══ NEW DIVAS ═══ -->
  <div class="view" id="view-consults">
    <div class="filter-row">
      <div class="chip on" onclick="fc(this)">All</div>
      <div class="chip" onclick="fc(this)">New</div>
      <div class="chip" onclick="fc(this)">Reviewed</div>
    </div>
    <div id="consults-list"><div class="data-note">Loading consultations…</div></div>
  </div>

  <!-- ═══ AVAILABILITY ═══ -->
  <div class="view" id="view-availability">
    <p style="font-size:13px;color:var(--t40);margin-bottom:20px;line-height:1.7;">Toggle days on/off and tap time slots to mark as available or blocked. Changes save automatically.</p>
    <div class="avail-grid" id="avail-grid"></div>
  </div>

  <!-- ═══ STOCK ═══ -->
  <div class="view" id="view-stock">
    <div class="stock-header">
      <div>
        <div class="label-caps" style="margin-bottom:4px;">Inventory</div>
        <div style="font-family:var(--font-d);font-size:26px;font-weight:400;">Stock Management</div>
      </div>
      <button class="add-btn" onclick="showToast('Add item — coming soon')">+ Add Item</button>
    </div>
    <div class="card" style="overflow-x:auto;">
      <table class="stock-table" id="stock-table">
        <thead><tr><th>Product</th><th>Category</th><th>Qty</th><th>Min</th><th>Actions</th></tr></thead>
        <tbody id="stock-body">
          <tr><td colspan="5"><div class="data-note">Loading stock…</div></td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ═══ INTEGRATIONS ═══ -->
  <div class="view" id="view-integrations">
    <div style="margin-bottom:20px;">
      <div class="label-caps" style="margin-bottom:6px;">Connected Services</div>
      <div style="font-family:var(--font-d);font-size:28px;font-weight:400;color:var(--t100);">Integrations</div>
      <div style="font-size:13px;color:var(--t40);margin-top:6px;line-height:1.7;">Toggle integrations on or off. Disabling will stop that service from being used in new bookings.</div>
    </div>

    <div class="integrations-grid">

      <!-- YOCO -->
      <div class="card card-grad-2 int-card yoco">
        <div class="int-header">
          <div style="display:flex;align-items:center;gap:14px;">
            <div class="int-icon">💳</div>
            <div>
              <div class="int-name">Yoco Payments</div>
